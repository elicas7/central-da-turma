# ──────────────────────────────────────────────────────
# CENTRAL DA TURMA — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados
# ──────────────────────────────────────────────────────

# Conexão com o banco PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://postgres:elias2011@localhost:5432/central_turma

# Segredo do JWT — use algo longo e aleatório em produção
JWT_SECRET=central_turma_nem_tenta_cuzao06-05

# Porta do servidor (padrão: 3000)
PORT=3000

# Duração do token JWT (ex: 7d, 24h)
JWT_EXPIRES_IN=7d

# Pasta onde os arquivos enviados serão salvos (relativo à raiz do projeto)
UPLOADS_DIR=./backend/uploads/materiais

# Em produção, defina NODE_ENV=production e ALLOWED_ORIGINS
# NODE_ENV=production
# ALLOWED_ORIGINS=https://seu-site.com
